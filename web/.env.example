# Backend base URL for agent HTTP endpoints (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional RPC overrides
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_TARGET_CHAIN_ID=
NEXT_PUBLIC_TARGET_RPC_URL=

# Explorer (optional). Defaults to Base Sepolia Basescan for chain 84532.
NEXT_PUBLIC_EXPLORER_BASE_URL=
NEXT_PUBLIC_TARGET_EXPLORER_BASE_URL=

# Chain ID contracts + wallet should use for reads/writes (default Base Sepolia)
NEXT_PUBLIC_EXPECTED_CHAIN_ID=84532

# Contract addresses (optional overrides)
NEXT_PUBLIC_SWARM_CONTRACT_ADDRESS=
NEXT_PUBLIC_META_SWARM_CONTRACT_ADDRESS=
NEXT_PUBLIC_AGENT_NFT_CONTRACT_ADDRESS=

# Structured activity API (optional). GET {BASE}/activity?threadId=...
NEXT_PUBLIC_ACTIVITY_API_BASE=

# Dynamic Labs (https://app.dynamic.xyz)
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
