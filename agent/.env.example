# 0G Chain Galileo RPC
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# Wallet private key (funded with A0GI for gas)
PRIVATE_KEY=0x...

# 0G Compute provider address (from broker.listService() or https://0g.ai/compute)
ZG_PROVIDER_ADDRESS=0x...

# 0G Storage Indexer URL
ZG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai

# 0G KV URL
ZG_KV_URL=https://...

# 32-byte hex key for AES-256-GCM encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZG_ENCRYPTION_KEY=

# SwarmMetaINFT contract address (from blockend/deployments.json)
SWARM_META_INFT_ADDRESS=0x...

# Optional: frontend URL for CORS (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Optional: server port (default: 8000)
PORT=8000
